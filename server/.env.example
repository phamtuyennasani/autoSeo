# Google Fonts API Key (https://console.cloud.google.com → Web Fonts API)
GOOGLE_FONTS_API_KEY=your_google_fonts_api_key_here

# Google Gemini API Key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Model Gemini sử dụng (tuỳ chọn, mặc định: gemini-2.5-flash)
# Các giá trị hợp lệ: gemini-2.5-flash, gemini-2.5-pro, gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-2.5-flash

# SerpAPI Key (https://serpapi.com)
# Hỗ trợ nhiều key cách nhau bởi dấu phẩy — tự động xoay vòng khi hết lượt (429)
# Ví dụ 1 key:  SERPAPI_API_KEY=abc123
# Ví dụ nhiều:  SERPAPI_API_KEY=key1,key2,key3
SERPAPI_API_KEY=your_serpapi_key_here


# Authentication (true = yêu cầu đăng nhập | false = bypass, dùng quyền admin)
AUTH_ENABLED=false

# JWT Secret (thay đổi giá trị này trước khi deploy!)
JWT_SECRET=autoseo-super-secret-key-change-this

# Encryption key cho API keys (AES-256-GCM)
# Tạo key mới: openssl rand -hex 32
# BẮT BUỘC phải có giá trị — server sẽ không khởi động nếu thiếu (production)
ENCRYPTION_KEY=

# Server Port
PORT=3001